POSTGRES_DB=event_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/event_system
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

APP_JWT_SECRET=use-a-long-random-secret-at-least-32-bytes-for-production

# docker compose: host ports (backend listens on 8080 inside the stack for nginx proxy)
BACKEND_PORT=8080
FRONTEND_PORT=4173
DB_PORT=5432
