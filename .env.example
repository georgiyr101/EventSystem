# Copy to .env and adjust. Used by docker compose (see docker-compose.yml).

POSTGRES_DB=event_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/event_system
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

APP_JWT_SECRET=use-a-long-random-secret-at-least-32-bytes-for-production

# Optional production-style JPA (set on Render + Neon)
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate
# SPRING_JPA_SHOW_SQL=false

# Optional bootstrap admin (leave empty to skip)
# APP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# APP_BOOTSTRAP_ADMIN_PASSWORD=
# APP_BOOTSTRAP_ADMIN_FULL_NAME=Administrator
